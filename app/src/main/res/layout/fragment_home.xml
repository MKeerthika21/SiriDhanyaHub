<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_header_green" android:orientation="vertical"
            android:padding="20dp" android:paddingBottom="32dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌾 Siri Dhanya Hub" android:textColor="#FFFFFF"
                android:textSize="26sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ಕರ್ನಾಟಕದ ಮಿಲೆಟ್ ಮೌಲ್ಯ ಸರಪಳಿ" android:textColor="#CCE8F5E9"
                android:textSize="14sp" android:layout_marginTop="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Karnataka's Millet Value Chain App" android:textColor="#99FFFFFF"
                android:textSize="12sp"/>

            <!-- Live Ticker -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_stat_overlay" android:orientation="vertical"
                android:padding="12dp" android:layout_marginTop="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📊 TODAY'S MANDI PRICES" android:textColor="#CCE8F5E9"
                    android:textSize="10sp" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tv_price1" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="🌾 Loading…"
                    android:textColor="#FFFFFF" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_price2" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text=""
                    android:textColor="#FFFFFF" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_price3" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text=""
                    android:textColor="#FFFFFF" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 4 Main Feature Cards -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Explore" android:textColor="@color/text_primary"
            android:textSize="18sp" android:textStyle="bold"
            android:paddingHorizontal="16dp" android:paddingTop="20dp" android:paddingBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="12dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp"
                android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp"
                style="@style/Widget.SiriDhanya.Card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/bg_header_amber" android:orientation="vertical"
                    android:gravity="center" android:padding="12dp" android:id="@+id/btn_go_mandi">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📈" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Mandi Watch" android:textColor="#FFFFFF"
                        android:textSize="13sp" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Live Prices" android:textColor="#CCE8F5E9" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp"
                android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp"
                style="@style/Widget.SiriDhanya.Card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/bg_header_green" android:orientation="vertical"
                    android:gravity="center" android:padding="12dp" android:id="@+id/btn_go_recipes">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🍱" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Recipe Lab" android:textColor="#FFFFFF"
                        android:textSize="13sp" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Kannada Recipes" android:textColor="#CCE8F5E9" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="12dp" android:paddingBottom="16dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp"
                android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp"
                style="@style/Widget.SiriDhanya.Card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/bg_header_terracotta" android:orientation="vertical"
                    android:gravity="center" android:padding="12dp" android:id="@+id/btn_go_health">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💚" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Health Benefits" android:textColor="#FFFFFF"
                        android:textSize="13sp" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nutrition Facts" android:textColor="#CCE8F5E9" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp"
                android:layout_height="120dp" android:layout_weight="1" android:layout_margin="4dp"
                style="@style/Widget.SiriDhanya.Card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/bg_header_amber" android:orientation="vertical"
                    android:gravity="center" android:padding="12dp" android:id="@+id/btn_go_buy">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🤝" android:textSize="32sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Buy Direct" android:textColor="#FFFFFF"
                        android:textSize="13sp" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Connect FPO" android:textColor="#CCE8F5E9" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Fun fact strip -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@color/surface_variant" android:padding="16dp"
            android:orientation="vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💡 Did You Know?" android:textColor="@color/primary"
                android:textSize="14sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Millets need 70% LESS water than rice. Growing millets helps fight climate change while keeping Karnataka farmers prosperous. 🌍"
                android:textColor="@color/text_secondary" android:textSize="13sp"
                android:layout_marginTop="4dp" android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
