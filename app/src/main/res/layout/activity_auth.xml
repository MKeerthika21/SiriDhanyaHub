<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="32dp">

    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="32dp"
        android:src="@mipmap/ic_launcher"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:text="Secure Access"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_logo" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Enter your 4-digit PIN"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <LinearLayout
        android:id="@+id/pin_indicators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle">

        <View
            android:id="@+id/dot1"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/pin_dot_off" />

        <View
            android:id="@+id/dot2"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/pin_dot_off" />

        <View
            android:id="@+id/dot3"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/pin_dot_off" />

        <View
            android:id="@+id/dot4"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/pin_dot_off" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/keypad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:columnCount="3"
        android:rowCount="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Buttons 1-9 -->
        <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn1" android:layout_width="0dp" android:layout_height="80dp" android:layout_columnWeight="1" android:text="1" android:textSize="24sp" android:textColor="@color/text_primary" />
        <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn2" android:layout_width="0dp" android:layout_height="80dp" android:layout_columnWeight="1" android:text="2" android:textSize="24sp" android:textColor="@color/text_primary" />
        <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn3" android:layout_width="0dp" android:layout_height="80dp" android:layout_columnWeight="1" android:text="3" android:textSize="24sp" android:textColor="@color/text_primary" />
        <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn4" android:layout_width="0dp" android:layout_height="80dp" android:layout_columnWeight="1" android:text="4" android:textSize="24sp" android:textColor="@color/text_primary" />
        <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn5" android:layout_width="0dp" android:layout_height="80dp" android:layout_columnWeight="1" android:text="5" android:textSize="24sp" android:textColor="@color/text_primary" />
        <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn6" android:layout_width="0dp" android:layout_height="80dp" android:layout_columnWeight="1" android:text="6" android:textSize="24sp" android:textColor="@color/text_primary" />
        <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn7" android:layout_width="0dp" android:layout_height="80dp" android:layout_columnWeight="1" android:text="7" android:textSize="24sp" android:textColor="@color/text_primary" />
        <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn8" android:layout_width="0dp" android:layout_height="80dp" android:layout_columnWeight="1" android:text="8" android:textSize="24sp" android:textColor="@color/text_primary" />
        <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn9" android:layout_width="0dp" android:layout_height="80dp" android:layout_columnWeight="1" android:text="9" android:textSize="24sp" android:textColor="@color/text_primary" />

        <!-- Biometric Button -->
        <com.google.android.material.button.MaterialButton
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:id="@+id/btn_biometric"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            app:icon="@drawable/ic_fingerprint"
            app:iconGravity="textStart"
            app:iconSize="32dp"
            app:iconTint="@color/primary" />

        <com.google.android.material.button.MaterialButton style="@style/Widget.MaterialComponents.Button.TextButton" android:id="@+id/btn0" android:layout_width="0dp" android:layout_height="80dp" android:layout_columnWeight="1" android:text="0" android:textSize="24sp" android:textColor="@color/text_primary" />

        <!-- Delete Button -->
        <com.google.android.material.button.MaterialButton
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            app:icon="@drawable/ic_backspace"
            app:iconGravity="textStart"
            app:iconSize="28dp"
            app:iconTint="@color/accent" />
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
